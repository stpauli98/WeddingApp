generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

/// Paketi za eventi — određuju maksimalan broj slika po gostu
/// Izvor istine za imageLimit/price je DB tabela `PricingPlan` (ne komentari ovdje).
enum PricingTier {
  free
  basic
  premium
  unlimited
}

// ──────────────────────────────────────
// Pricing Plans (dinamičke cijene iz baze)
// ──────────────────────────────────────

/// Plan — definicija paketa sa cijenama i limitima
model PricingPlan {
  id           String      @id @default(uuid())
  tier         PricingTier @unique
  nameSr       String
  nameEn       String
  imageLimit   Int
  price        Int         @default(0)    // cijena u centima (0 = besplatno)
  recommended  Boolean     @default(false)
  sortOrder    Int         @default(0)
  active       Boolean     @default(true)
  /// LS variant ID — allowlist for webhook variant_id verification.
  /// Null for free tier (not purchasable). Sync from env vars via seed.ts.
  lsVariantId  String?     @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  features     PricingFeature[]
}

/// Feature — feature lista za svaki plan
model PricingFeature {
  id           String      @id @default(uuid())
  planId       String
  textSr       String
  textEn       String
  sortOrder    Int         @default(0)
  plan         PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

// ──────────────────────────────────────
// Admin & Autentifikacija
// ──────────────────────────────────────

/// Admin (mladenci) — kreira event i pregledava slike/poruke gostiju
model Admin {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  firstName    String
  lastName     String
  language     String         @default("sr")
  /// GDPR opt-in for product/marketing emails. Default false — opt-in UI
  /// can be added in admin settings later. Cron only harvests when true.
  marketingConsent Boolean    @default(false)
  createdAt    DateTime       @default(now())
  sessions     AdminSession[]
  event        Event?         @relation("AdminEvent")
}

/// Admin sesija — httpOnly cookie, traje 7 dana
model AdminSession {
  id           String   @id @default(uuid())
  adminId      String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  admin        Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([expiresAt])
}

// ──────────────────────────────────────
// Event
// ──────────────────────────────────────

/// Svadbeni event — identifikuje se po slug-u (npr. /guest/login?event=marko-i-ana)
/// Jedan admin ima tačno jedan event (1:1 relacija preko adminId)
model Event {
  id                    String      @id @default(uuid())
  slug                  String      @unique
  coupleName            String
  location              String
  date                  DateTime
  guestMessage          String?
  language              String      @default("sr")
  imageLimit            Int         @default(10)
  pricingTier           PricingTier @default(free)
  /// Additional days admin granted beyond tier's storageDays (0..365).
  /// Used by retention cron when computing expiry.
  retentionOverrideDays Int         @default(0)
  createdAt             DateTime    @default(now())
  /// Set when the 2-day deletion warning email has been sent (idempotency guard).
  deletionWarningSentAt DateTime?
  /// Set when retention-based hard delete of guest data completed. Event row stays.
  deletedAt             DateTime?
  adminId               String?     @unique
  admin                 Admin?      @relation("AdminEvent", fields: [adminId], references: [id])
  guests                Guest[]
  payments              Payment[]
  /// C3: Grandfather flag for events created before payment infrastructure.
  /// Exempts event from "paid tier without Payment" audit invariant and
  /// from maxRetentionOverrideDays cap.
  legacyGrandfathered   Boolean     @default(false)

  @@index([deletedAt])
}

// ──────────────────────────────────────
// Payments
// ──────────────────────────────────────

enum PaymentStatus {
  pending
  paid
  refunded
  partial
  failed
}

/// Payment — immutable audit trail of a single transaction. Upgrades produce
/// new rows. Refunds update the existing row (refundedAmountCents + status).
model Payment {
  id                  String        @id @default(uuid())
  eventId             String
  tier                PricingTier
  amountCents         Int
  currency            String        @default("EUR")
  status              PaymentStatus
  lsCheckoutId        String        @unique
  lsOrderId           String?       @unique
  lsEventId           String?       @unique
  refundedAmountCents Int           @default(0)
  refundedAt          DateTime?
  customerEmail       String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  event               Event         @relation(fields: [eventId], references: [id], onDelete: Restrict)

  @@index([eventId, status])
  @@index([createdAt])
}

/// WebhookLog — forensic trail of every Lemon Squeezy webhook.
/// signatureValid=false rows are likely attacks or misconfig.
/// payload is PII-scrubbed via lib/webhook-scrub.ts (customer_name, billing_address removed).
model WebhookLog {
  id             String    @id @default(uuid())
  lsEventId      String?   @unique
  eventName      String?
  signatureValid Boolean
  payload        Json
  error          String?
  processedAt    DateTime?
  sourceIp       String?
  createdAt      DateTime  @default(now())

  @@index([signatureValid, createdAt])
  @@index([eventName])
}

// ──────────────────────────────────────
// Gost & Sadržaj
// ──────────────────────────────────────

/// Gost — registruje se imenom i emailom, auto-verifikovan (bez email kodova)
/// Isti email može biti gost na više evenata, ali samo jednom po eventu
model Guest {
  id               String    @id @default(uuid())
  email            String
  firstName        String
  lastName         String
  eventId          String
  sessionToken     String?
  sessionExpires   DateTime?
  /// GDPR opt-in at registration. When true, email is harvested into
  /// MarketingContact at retention expiry.
  marketingConsent Boolean   @default(false)
  createdAt        DateTime  @default(now())
  event            Event     @relation(fields: [eventId], references: [id])
  images           Image[]
  message          Message?

  @@unique([email, eventId])
  @@index([eventId])
  @@index([sessionToken])
}

/// Slika — upload na Cloudinary, storagePath = Cloudinary public_id za brisanje
model Image {
  id          String   @id @default(uuid())
  guestId     String
  imageUrl    String
  storagePath String?
  createdAt   DateTime @default(now())
  guest       Guest    @relation(fields: [guestId], references: [id])

  @@index([guestId, createdAt(sort: Desc)])
  @@index([createdAt])
}

/// Poruka — čestitka gosta, max jedna po gostu (1:1)
model Message {
  id        String   @id @default(uuid())
  guestId   String   @unique
  text      String
  createdAt DateTime @default(now())
  guest     Guest    @relation(fields: [guestId], references: [id])
}

// ──────────────────────────────────────
// Marketing
// ──────────────────────────────────────

/// Marketing contact — harvested at retention expiry for consented guests / admins.
/// Separate from operational tables so GDPR unsubscribe + cleanup stay simple.
model MarketingContact {
  id             String    @id @default(uuid())
  email          String
  /// "guest" (harvested from Guest on event deletion) or "admin" (harvested once per admin)
  source         String
  eventSlug      String?
  coupleName     String?
  weddingDate    DateTime?
  consentedAt    DateTime
  harvestedAt    DateTime  @default(now())
  unsubscribedAt DateTime?
  /// Opaque token issued at harvest time — embedded in marketing email links
  /// so recipients can unsubscribe without authenticating.
  unsubscribeToken String? @unique

  @@unique([email, source])
  @@index([source])
}
