# Database (Prisma)
DATABASE_URL=
DIRECT_DATABASE_URL=

# CSRF — base64-encoded 32-byte secret
CSRF_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Upstash Redis — REQUIRED in production for rate-limiting.
# Without these set, rate-limit falls back to per-lambda in-memory
# which is ineffective under serverless. App will fail to boot
# in production if these are absent.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin email (currently unused — email flow is stubbed in lib/email.ts)
ADMIN_EMAIL=
ADMIN_EMAIL_PASSWORD=

# Prisma Optimize (dev slow-query logging)
OPTIMIZE_API_KEY=

# NextAuth / Google OAuth — reserved for future use; no active code path
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron (if enabled) — protects /api/cron/* routes
CRON_SECRET=
